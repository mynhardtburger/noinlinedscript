pipeline {
    stages {
        stage('Build') {
            steps {
                sh '''#!/bin/bash
                    set -e
                    echo "=== Running setup ==="
                    if ! command -v uv &>/dev/null; then
                        curl -LsSf https://astral.sh/uv/install.sh | sh
                    fi
                    echo "uv version: $(uv --version)"
                '''
            }
        }
    }
}
